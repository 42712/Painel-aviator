{
  "manifest_version": 3,
  "name": "Painel Aviator - Coletor Betou",
  "version": "4.0",
  "description": "Captura rodadas do Aviator na Betou em tempo real: vela, rodada, horário, soma. Envia para o painel.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://betou.bet.br/*",
    "https://*.betou.bet.br/*",
    "https://*.spribegaming.com/*",
    "https://ssp.betou.bet.br/*",
    "https://load.ssp.betou.bet.br/*",
    "https://painel-aviator.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://betou.bet.br/*",
        "https://*.betou.bet.br/*",
        "https://*.spribegaming.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  }
}
