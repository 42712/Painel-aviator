{
  "manifest_version": 3,
  "name": "Megatron Aviator Realtime WS",
  "version": "5.0",
  "description": "Captura velas, rodada e horário do Aviator em tempo real via WebSocket.",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://*.spribegaming.com/*",
    "https://*.bet.br/*",
    "https://*.aviatorx.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.spribegaming.com/*",
        "https://*.bet.br/*",
        "https://*.aviatorx.app/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ]
}
