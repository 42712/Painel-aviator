# content.js

```javascript
(function () {

    'use strict';

    console.log('[MEGATRON] iniciado');

    const OriginalWebSocket = window.WebSocket;

    let lastMultiplier = null;
    let lastRound = null;

    function sendData(data) {

        try {

            chrome.runtime.sendMessage({
                type: 'AVIATOR_DATA',
                data
            });

        } catch (e) {}

    }

    function getTimeNow() {

        const d = new Date();

        return d.toLocaleTimeString('pt-BR');

    }

    function processMessage(raw) {

        try {

            const text = String(raw);

            // ROUND ID
            const roundMatch = text.match(/round(Id)?["=: ]+(\d+)/i);

            if (roundMatch) {
                lastRound = roundMatch[2];
                console.log('🆔 ROUND:', lastRound);
            }

            // MULTIPLIER
            const multMatch = text.match(/(\d+\.\d+)x?/);

            if (multMatch) {

                const mult = parseFloat(multMatch[1]);

                if (!isNaN(mult) && mult >= 1) {

                    if (mult !== lastMultiplier) {

                        lastMultiplier = mult;

                        const payload = {
                            multiplier: mult,
                            round: lastRound,
                            time: getTimeNow(),
                            raw: text
                        };

                        console.log('🎯 MULT:', payload);

                        sendData(payload);

                    }

                }

            }

            // CRASH
            const crashMatch = text.match(/crash["=: ]+([\d.]+)/i);

            if (crashMatch) {

                const payload = {
                    type: 'CRASH',
                    multiplier: parseFloat(crashMatch[1]),
                    round: lastRound,
                    time: getTimeNow(),
                    raw: text
                };

                console.log('💥 CRASH:', payload);

                sendData(payload);

            }

        } catch (err) {

            console.warn('[MEGATRON] erro processando:', err);

        }

    }

    window.WebSocket = function (...args) {

        console.log('🟢 WS OPEN:', args[0]);

        const ws = new OriginalWebSocket(...args);

        // SEND
        const originalSend = ws.send;

        ws.send = function (data) {

            console.log('📤 WS SEND:', data);

            return originalSend.apply(this, arguments);

        };

        // RECEIVE
        ws.addEventListener('message', async (event) => {

            try {

                let data = event.data;

                if (data instanceof Blob) {
                    data = await data.text();
                }

                console.log('📥 WS RECEIVE:', data);

                // SockJS
                if (typeof data === 'string' && data.startsWith('a[')) {

                    const arr = JSON.parse(data);

                    arr.forEach(msg => {

                        console.log('📦 FRAME:', msg);

                        processMessage(msg);

                    });

                } else {

                    processMessage(data);

                }

            } catch (e) {

                console.warn('[MEGATRON] erro ws:', e);

            }

        });

        return ws;

    };

    // FALLBACK DOM
    setInterval(() => {

        try {

            const payouts = document.querySelectorAll('.payout');

            if (!payouts.length) return;

            const last = payouts[0];

            const txt = last.innerText.trim();

            const mult = parseFloat(txt.replace('x', ''));

            if (!isNaN(mult) && mult !== lastMultiplier) {

                lastMultiplier = mult;

                const payload = {
                    type: 'DOM_FALLBACK',
                    multiplier: mult,
                    round: lastRound,
                    time: getTimeNow()
                };

                console.log('🟣 DOM:', payload);

                sendData(payload);

            }

        } catch (e) {}

    }, 1000);

})();
```

