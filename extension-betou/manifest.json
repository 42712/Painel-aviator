{
  "manifest_version": 3,
  "name": "Betou Coletor",
  "version": "1.1",
  "description": "Coleta rodadas do Aviator Betou e envia para o painel",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://painel-aviator.onrender.com/*",
    "https://*.betou.bet.br/*",
    "https://*.spribegaming.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.betou.bet.br/*",
        "https://*.spribegaming.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Betou Coletor"
  }
}
