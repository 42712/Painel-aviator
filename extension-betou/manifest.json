{
  "manifest_version": 3,
  "name": "Painel Aviator Betou",
  "version": "4.1",
  "description": "Coletor de rodadas Aviator Betou - captura WebSocket, vela, horário (HH:MM:SS), soma. Funciona em PC e celular (Kiwi).",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://betou.bet.br/*",
    "https://*.betou.bet.br/*",
    "https://*.spribegaming.com/*",
    "https://ssp.betou.bet.br/*",
    "https://load.ssp.betou.bet.br/*",
    "https://painel-aviator.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://betou.bet.br/*",
        "https://*.betou.bet.br/*",
        "https://*.spribegaming.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [{
    "resources": ["main-world.js"],
    "matches": ["https://betou.bet.br/*", "https://*.betou.bet.br/*", "https://*.spribegaming.com/*"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Painel Aviator Betou",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  }
}
